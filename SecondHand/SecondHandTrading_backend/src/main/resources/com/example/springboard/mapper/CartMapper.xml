<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboard.mapper.CartMapper">
    <resultMap id="CartWithProductResultMap" type="com.example.springboard.pojo.Cart">
        <id column="cartId" property="cartId"/>
        <result column="userId" property="userId"/>
        <result column="productId" property="productId"/>
        <result column="cartSize" property="cartSize"/>
        <result column="cartNum" property="cartNum"/>
        <result column="createTime" property="createTime"/>

        <!-- 关联单个商品 -->
        <collection  property="product" javaType="com.example.springboard.pojo.Product">
            <id column="productId" property="productId"/>
            <result column="productName" property="productName"/>
            <result column="productPhoto" property="productPhoto"/>
            <result column="productType" property="productType"/>
            <result column="productPrice" property="productPrice"/>
            <result column="productState" property="productState"/>
            <result column="productSales" property="productSales"/>
            <result column="productNum" property="productNum"/>
            <result column="productInfo" property="productInfo"/>
            <result column="createTime" property="createTime"/>
            <result column="updateTime" property="updateTime"/>
        </collection >
    </resultMap>

    <!-- 查询SQL -->
    <select id="showAll" resultMap="CartWithProductResultMap">
        SELECT * FROM cart c LEFT JOIN product p ON c.productId = p.productId
    </select>

</mapper>